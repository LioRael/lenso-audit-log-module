{
  "name": "@lenso/audit-log-release-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "cargo fmt --all --check && cargo test --locked && cargo clippy --locked --workspace --all-targets -- -D warnings",
    "release:intent-check": "node scripts/release-plan.mjs --check-intent",
    "release:plan": "node scripts/release-plan.mjs",
    "release:verify": "npm run check && node scripts/release-plan.mjs --verify"
  },
  "devDependencies": {
    "tegami": "1.2.5"
  },
  "packageManager": "pnpm@11.7.0"
}
